(require "tests/test")

;; var-quote reader macro and var special form tests

(deftest var-returns-value
  (let [x 42]
    (is (= (var x) 42))))

(deftest var-quote-reader-macro
  (let [x 99]
    (is (= #'x 99))))

(deftest var-on-function
  (is (= (var inc) inc)))

(deftest var-quote-on-function
  (is (= #'inc inc)))

(deftest var-quote-round-trip
  (let [f #'map]
    (is (= f map))))
