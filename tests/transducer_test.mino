;; Tests for transducers: transduce, into with xf, composed xforms.

;; --- transduce ---

(deftest transduce-map
  (is (= 9 (transduce (map inc) + [1 2 3])))
  (is (= 9 (transduce (map inc) + 0 [1 2 3])))
  (is (= 10 (transduce (map inc) + 1 [1 2 3]))))

(deftest transduce-filter
  (is (= 9 (transduce (filter odd?) + 0 [1 2 3 4 5])))
  (is (= 6 (transduce (filter even?) + 0 [1 2 3 4 5]))))

(deftest transduce-remove
  (is (= 9 (transduce (remove even?) + 0 [1 2 3 4 5]))))

(deftest transduce-take
  (is (= [1 2 3] (transduce (take 3) conj [] [1 2 3 4 5])))
  (is (= [1 2 3] (transduce (take 5) conj [] [1 2 3]))))

(deftest transduce-drop
  (is (= [3 4 5] (transduce (drop 2) conj [] [1 2 3 4 5])))
  (is (= [] (transduce (drop 10) conj [] [1 2 3]))))

(deftest transduce-take-while
  (is (= [1 2 3] (transduce (take-while #(< % 4)) conj [] [1 2 3 4 5]))))

(deftest transduce-drop-while
  (is (= [3 4 5] (transduce (drop-while #(< % 3)) conj [] [1 2 3 4 5]))))

(deftest transduce-keep
  (is (= [4 16] (transduce (keep #(when (even? %) (* % %))) conj [] [1 2 3 4 5]))))

(deftest transduce-distinct
  (is (= [1 2 3] (transduce (distinct) conj [] [1 2 1 3 2 3]))))

(deftest transduce-dedupe
  (is (= [1 2 3 1] (transduce (dedupe) conj [] [1 1 2 2 3 1]))))

(deftest transduce-cat
  (is (= [1 2 3 4 5] (transduce cat conj [] [[1 2] [3 4] [5]]))))

(deftest transduce-mapcat
  (is (= [1 1 2 2 3 3] (transduce (mapcat #(list % %)) conj [] [1 2 3]))))

(deftest transduce-interpose
  (is (= [1 :sep 2 :sep 3] (transduce (interpose :sep) conj [] [1 2 3]))))

(deftest transduce-partition-all
  (is (= ['(1 2) '(3 4) '(5)] (transduce (partition-all 2) conj [] [1 2 3 4 5])))
  (is (= ['(1 2 3)] (transduce (partition-all 3) conj [] [1 2 3]))))

(deftest transduce-partition-by
  (is (= [[1 3] [2 4] [5]] (transduce (partition-by odd?) conj [] [1 3 2 4 5]))))

;; --- Composition ---

(deftest transduce-comp
  (is (= 12 (transduce (comp (map inc) (filter even?)) + 0 [1 2 3 4 5])))
  (is (= [2 4 6] (transduce (comp (filter odd?) (map inc)) conj [] [1 2 3 4 5])))
  (is (= [2 3] (transduce (comp (map inc) (take 2)) conj [] [1 2 3 4 5])))
  (is (= ['(2 3) '(4 5)] (transduce (comp (map inc) (partition-all 2)) conj [] [1 2 3 4]))))

;; --- into with xform ---

(deftest into-with-xform-vector
  (is (= [2 3 4] (into [] (map inc) [1 2 3])))
  (is (= [1 3 5] (into [] (filter odd?) [1 2 3 4 5]))))

(deftest into-with-xform-set
  (is (= #{2 3 4} (into #{} (map inc) [1 2 3]))))

(deftest into-with-xform-map
  (is (= {1 1 2 4 3 9} (into {} (map #(vector % (* % %))) [1 2 3]))))

(deftest into-with-xform-existing
  (is (= [0 2 3 4] (into [0] (map inc) [1 2 3]))))

;; --- sequence / eduction ---

(deftest sequence-basic
  (is (= '(2 3 4) (sequence (map inc) [1 2 3])))
  (is (= '(1 3 5) (sequence (filter odd?) [1 2 3 4 5]))))

;; --- Early termination ---

(deftest transduce-early-termination
  (is (= [0 1 2] (into [] (take 3) (range 1000))))
  (is (= [1 2 3] (into [] (comp (drop 0) (take 3)) [1 2 3 4 5]))))

;; --- Empty collections ---

(deftest transduce-empty
  (is (= 0 (transduce (map inc) + 0 [])))
  (is (= [] (into [] (map inc) [])))
  (is (= [] (into [] (filter odd?) []))))

;; --- Deref on reduced ---

(deftest deref-reduced
  (is (= 42 @(reduced 42)))
  (is (= nil @(reduced nil))))
