(require "tests/test")

;; ns special form tests

(deftest ns-basic-accepted
  (is (nil? (ns test.ns.basic))))

(deftest ns-with-empty-require
  (is (nil? (ns test.ns.req
              (:require)))))

(deftest ns-skips-unknown-clauses
  (is (nil? (ns test.ns.skip
              (:import java.util.Date)
              (:gen-class)))))
