{ :vcs        :git                                 ; mino commits via git (the .jj/ dir is a stale leftover)
 :languages  [:c :clojure]                        ; C host runtime + Clojure dialect (consumer last)
 :ui?        false                                ; runtime/VM project, no frontend surface

 :architecture
 {:pattern      :functional-core-imperative-shell ; pure Clojure core, C imperative shell
  :native-edge? true                              ; Clojure dialect calls into C at the host boundary
  :modules      {"async"       "src/async"
                 "collections" "src/collections"
                 "diag"        "src/diag"
                 "eval"        "src/eval"
                 "gc"          "src/gc"
                 "interop"     "src/interop"
                 "prim"        "src/prim"
                 "public"      "src/public"
                 "regex"       "src/regex"
                 "runtime"     "src/runtime"
                 "values"      "src/values"}}

 :lanes
 {:cheap    ["make"]                              ; bootstrap build: regen bundled headers, compile ./mino
  :wave     ["./mino task build-asan"             ; sanitizer tier (needs ./mino built)
             "./mino task build-ubsan"]
  :pre-land ["make"                               ; full gate: clean build + sanitizers + tests
             "./mino task build-asan"
             "./mino task test"]}

 :dimensions-active #{:correctness :factoring :style :conformance
                      :security :performance :memory :portability}

  :spine
  {:runtime     :mino                              ; mino self-host: spine runs on the mino runtime
   :store       :edn
   :working-dir ".agentic-sdk/state/"}

 :adr        {:store "docs/adr/" :format :nygard} ; mino already tracks docs/adr/

 :commit     {:categories ["Build" "Tests" "Fix" "Refactor" "Docs" "CI" "Skills"]
              :form      "Category: Imperative subject"}

 :hooks      [:format-on-write :deny-secrets :require-tests-before-land]

 :permissions {:bash ["make"                      ; the bootstrap Makefile
                      "./mino *"                  ; mino task runner (build/test/sanitizers)
                      "bb *"                      ; spine tasks + hook scripts
                      "git status"                ; read-only git
                      "git diff"
                      "git log"
                      "git show"]}

 :runtimes   [:claude-code :opencode]}            ; master format + derived projection
